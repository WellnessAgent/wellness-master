# wellness-master MCP — client-only config
#
# All values are OPTIONAL. The four free MCP tools (list_formats,
# list_languages, get_catalog, get_health) work with no .env at all.
# The two paid tools (get_item, get_pack) need a Solana keypair.

# Wellness API endpoint (defaults to the public production API)
SERVER_BASE=https://api.wls-ms.com

# Solana network — "solana" (mainnet, default) or "solana-devnet" (testing)
NETWORK=solana

# Path to a Solana keypair JSON file. Auto-created on first paid call.
# Mode 0600. NEVER commit. ANYONE with this file can spend its USDC.
CLIENT_KEYPAIR_PATH=.local/client-keypair.json

# Optional: encrypt the keypair at rest (AES-256-GCM + scrypt-derived key).
# Set this BEFORE the first paid call, and the keypair will be created
# already-encrypted. Cannot be added after the fact without re-creating.
# CLIENT_KEYPAIR_PASSPHRASE=your-strong-passphrase

# Optional: custom Solana RPC endpoint used when signing the x402 payment.
# Defaults to https://api.mainnet-beta.solana.com (or devnet if NETWORK is solana-devnet).
# CLIENT_RPC_URL=https://your-rpc-provider.com
